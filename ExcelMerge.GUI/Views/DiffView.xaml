<UserControl x:Class="ExcelMerge.GUI.Views.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:ExcelMerge.GUI.Views"
             xmlns:behavior="clr-namespace:ExcelMerge.GUI.Behaviors"
             xmlns:fg="clr-namespace:FastWpfGrid;assembly=FastWpfGrid"
             xmlns:props="clr-namespace:ExcelMerge.GUI.Properties"
             xmlns:gui="clr-namespace:ExcelMerge.GUI"
             xmlns:vc="clr-namespace:ExcelMerge.GUI.ValueConverters"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="300" d:DesignWidth="300"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             >

  <Grid>

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5*"/>                                          <!-- Col 0: SrcMap -->
      <ColumnDefinition Width="45*"/>                                         <!-- Col 1: SrcGrid (THEIRS) -->
      <ColumnDefinition Width="Auto"/>                                        <!-- Col 2: Splitter -->
      <ColumnDefinition x:Name="BaseColumnDef" Width="0"/>                    <!-- Col 3: BaseGrid (hidden by default) -->
      <ColumnDefinition x:Name="BaseSplitterColumnDef" Width="0"/>            <!-- Col 4: Splitter2 (hidden by default) -->
      <ColumnDefinition Width="45*"/>                                         <!-- Col 5: DstGrid (MINE) -->
      <ColumnDefinition Width="5*"/>                                          <!-- Col 6: DstMap -->
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ============ Toolbar Background ============ -->
    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="7"
            Background="{StaticResource ToolbarBgBrush}"/>

    <!-- ============ File Paths Row (aligned to grid columns) ============ -->

    <!--Src file path: Column 1, aligned with SrcDataGrid-->
    <Grid Grid.Row="1" Grid.Column="1" Margin="1,3,1,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="{x:Static props:Resources.Word_SrcFile}" VerticalAlignment="Center"
                 Margin="2,0,6,0" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeSmall}"/>
      <Grid Grid.Column="1">
        <TextBox x:Name="SrcPathTextBox" AcceptsReturn="False" Padding="6,4,28,4"
                 AllowDrop="True"
                 Text="{Binding SrcPath}"
                 KeyDown="PathTextBox_KeyDown"
                 TextChanged="PathTextBox_TextChanged"
                 Tag="0">
          <i:Interaction.Behaviors>
            <behavior:DragAcceptBehavior
                Description="{Binding DataContext. Description,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          </i:Interaction.Behaviors>
        </TextBox>
        <Button x:Name="SrcBrowseButton"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,3,0"
                Style="{StaticResource ToolbarButton}" Padding="3,2"
                Click="SrcBrowseButton_Click" ToolTip="Browse..."
                Focusable="False">
          <Path Data="M2,4 L2,14 L16,14 L16,6 L9,6 L7,4 Z M0,2 L8,2 L10,4 L18,4 L18,16 L0,16 Z"
                Fill="#8E95A2" Width="14" Height="12" Stretch="Uniform"/>
        </Button>
      </Grid>
      <TextBlock Grid.Column="2" Text="{x:Static props:Resources.Word_Sheet}" VerticalAlignment="Center"
                 Margin="6,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeSmall}"/>
      <ComboBox x:Name="SrcSheetCombobox" Grid.Column="3" MinWidth="120" MaxWidth="300"
                ItemsSource="{Binding SrcSheetNames}"
                SelectedIndex="{Binding SelectedSrcSheetIndex}"/>
    </Grid>

    <!--Swap button: Column 2, between the two grids-->
    <Button x:Name="SwapButton" Grid.Row="1" Grid.Column="2"
            Style="{StaticResource ToolbarButton}" Padding="4,3"
            Click="SwapButton_Click"
            ToolTip="{x:Static props:Resources.ToolTip_Swap}"
            IsEnabled="{Binding Executable}"
            VerticalAlignment="Center">
      <Grid Width="18" Height="12">
        <Path Data="M0,2 L5,0 L5,4 Z" Fill="#3B82F6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Path Data="M18,10 L13,8 L13,12 Z" Fill="#3B82F6" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        <Line X1="1" Y1="2" X2="17" Y2="2" Stroke="#3B82F6" StrokeThickness="1"/>
        <Line X1="1" Y1="10" X2="17" Y2="10" Stroke="#3B82F6" StrokeThickness="1"/>
      </Grid>
    </Button>

    <!--Dst file path: Column 5, aligned with DstDataGrid-->
    <Grid Grid.Row="1" Grid.Column="5" Margin="1,3,1,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="{x:Static props:Resources.Word_DstFile}" VerticalAlignment="Center"
                 Margin="2,0,6,0" FontWeight="Medium" Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeSmall}"/>
      <Grid Grid.Column="1">
        <TextBox x:Name="DstPathTextBox" AcceptsReturn="False" Padding="6,4,28,4"
                 AllowDrop="True"
                 Text="{Binding DstPath}"
                 KeyDown="PathTextBox_KeyDown"
                 TextChanged="PathTextBox_TextChanged"
                 Tag="1">
          <i:Interaction.Behaviors>
            <behavior:DragAcceptBehavior
                Description="{Binding DataContext. Description,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
          </i:Interaction.Behaviors>
        </TextBox>
        <Button x:Name="DstBrowseButton"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,3,0"
                Style="{StaticResource ToolbarButton}" Padding="3,2"
                Click="DstBrowseButton_Click" ToolTip="Browse..."
                Focusable="False">
          <Path Data="M2,4 L2,14 L16,14 L16,6 L9,6 L7,4 Z M0,2 L8,2 L10,4 L18,4 L18,16 L0,16 Z"
                Fill="#8E95A2" Width="14" Height="12" Stretch="Uniform"/>
        </Button>
      </Grid>
      <TextBlock Grid.Column="2" Text="{x:Static props:Resources.Word_Sheet}" VerticalAlignment="Center"
                 Margin="6,0,4,0" Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="{StaticResource FontSizeSmall}"/>
      <ComboBox x:Name="DstSheetCombobox" Grid.Column="3" MinWidth="120" MaxWidth="300"
                ItemsSource="{Binding DstSheetNames}"
                SelectedIndex="{Binding SelectedDstSheetIndex}"/>
    </Grid>

    <!-- ============ Toolbar Row ============ -->
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7"
            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="4,0">
      <StackPanel Orientation="Horizontal">

          <!--── Group: Diff ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Diff" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <Button x:Name="DiffButton"
                        Style="{StaticResource ToolbarPrimaryButton}"
                        Click="DiffButton_Click"
                        IsEnabled="{Binding Executable}"
                        Padding="10,4">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="M2,0 L10,0 L14,4 L14,16 L2,16 Z M10,0 L10,4 L14,4"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.2" Fill="Transparent"
                          Width="14" Height="16" Stretch="Uniform" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static props:Resources.Button_ExtractDiff}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Merge ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Merge" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <CheckBox x:Name="ShowBaseToggle"
                          Margin="4,2"
                          VerticalAlignment="Center"
                          Content="BASE"
                          Checked="ShowBaseToggle_Checked"
                          Unchecked="ShowBaseToggle_Unchecked"
                          ToolTip="Show/Hide BASE panel (3-way merge)"
                          IsEnabled="False"/>
                <TextBlock x:Name="ConflictCountLabel" VerticalAlignment="Center" Margin="6,0,4,0"
                           FontSize="11" Foreground="#DC2626" Visibility="Collapsed"/>
                <Button x:Name="SaveMergeButton"
                        Click="SaveMergeButton_Click"
                        Padding="10,4">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="M3,0 L13,0 L13,12 L8,16 L3,12 Z M6,8 L10,8 L10,4 L6,4 Z"
                          Fill="#10B981" Width="14" Height="16" Stretch="Uniform" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static props:Resources.Button_SaveMerge}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: History ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="History" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <Button x:Name="HistoryButton" Style="{StaticResource ToolbarButton}"
                        Padding="6,3" Click="HistoryButton_Click">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="M8,0 A8,8 0 1 0 16,8 A8,8 0 1 0 8,0 M8,3 L8,9 L12,9"
                          Stroke="#5F6672" StrokeThickness="1.4" Fill="Transparent"
                          Width="15" Height="15" Stretch="Uniform"/>
                    <Path Data="M0,0 L4,3 L8,0" Stroke="#5F6672" StrokeThickness="1.2" Fill="Transparent"
                          Width="8" Height="4" Stretch="Uniform" Margin="2,0,0,0" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Display ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="{x:Static props:Resources.GroupBox_DisplayFormat}" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <RadioButton x:Name="ShowAllRadioButton" Content="{x:Static props:Resources.RadioButton_ShowAll}"
                             Margin="4,2" IsChecked="True"
                             Checked="ShowAllRadioButton_Checked"/>
                <RadioButton x:Name="ShowOnlyDiffRadioButton" Content="{x:Static props:Resources.RadioButton_ShowOnlyDiff}"
                             Margin="4,2" IsChecked="False"
                             Checked="ShowOnlyDiffRadioButton_Checked"/>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Compare Mode ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Compare" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <CheckBox x:Name="CompareFormulaCheckbox" Content="Formula" Margin="4,2"
                          Checked="CompareFormulaCheckbox_Changed" Unchecked="CompareFormulaCheckbox_Changed"/>
                <CheckBox x:Name="IgnoreWhitespaceCheckbox" Content="Trim" Margin="4,2"
                          ToolTip="Ignore leading/trailing whitespace"
                          Checked="IgnoreRulesChanged" Unchecked="IgnoreRulesChanged"/>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Tolerance ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Tolerance" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <TextBox x:Name="NumericPrecisionTextBox" Width="50" Margin="4,2" Text="0"
                         ToolTip="Numeric precision tolerance (0=exact)"
                         LostFocus="IgnoreRulesChanged"/>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Navigate ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Navigate" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,2,0,0">

                <!--Modified Cells-->
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevModifiedCellButton" Style="{StaticResource ToolbarButton}"
                            Content="◀" FontSize="11" Padding="5,2"
                            Click="PrevModifiedCellButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_Left}"/>
                    <Button x:Name="NextModifiedCellButton" Style="{StaticResource ToolbarButton}"
                            Content="▶" FontSize="11" Padding="5,2"
                            Click="NextModifiedCellButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_Right}"/>
                  </StackPanel>
                  <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{Binding ModifiedCellCount, StringFormat='{}{0}', Mode=OneWay}"/> <Run Text="cells"/>
                  </TextBlock>
                </StackPanel>

                <Border Width="1" Background="{StaticResource BorderLightBrush}" Margin="4,2,4,0"/>

                <!--Modified Rows-->
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevModifiedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="◀" FontSize="11" Padding="5,2"
                            Click="PrevModifiedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_Up}"/>
                    <Button x:Name="NextModifiedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="▶" FontSize="11" Padding="5,2"
                            Click="NextModifiedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_Down}"/>
                  </StackPanel>
                  <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{Binding ModifiedRowCount, StringFormat='{}{0}', Mode=OneWay}"/> <Run Text="rows"/>
                  </TextBlock>
                </StackPanel>

                <Border Width="1" Background="{StaticResource BorderLightBrush}" Margin="4,2,4,0"/>

                <!--Added Rows-->
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevAddedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="◀" FontSize="11" Padding="5,2"
                            Click="PrevAddedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_I}"/>
                    <Button x:Name="NextAddedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="▶" FontSize="11" Padding="5,2"
                            Click="NextAddedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_K}"/>
                  </StackPanel>
                  <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="#16A34A">
                    <Run Text="{Binding AddedRowCount, StringFormat='{}{0}', Mode=OneWay}"/> <Run Text="added"/>
                  </TextBlock>
                </StackPanel>

                <Border Width="1" Background="{StaticResource BorderLightBrush}" Margin="4,2,4,0"/>

                <!--Removed Rows-->
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PrevRemovedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="◀" FontSize="11" Padding="5,2"
                            Click="PrevRemovedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_O}"/>
                    <Button x:Name="NextRemovedRowButton" Style="{StaticResource ToolbarButton}"
                            Content="▶" FontSize="11" Padding="5,2"
                            Click="NextRemovedRowButton_Click"
                            ToolTip="{x:Static props:Resources.Shortcut_Ctrl_L}"/>
                  </StackPanel>
                  <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="#DC2626">
                    <Run Text="{Binding RemovedRowCount, StringFormat='{}{0}', Mode=OneWay}"/> <Run Text="removed"/>
                  </TextBlock>
                </StackPanel>

              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Search ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="{x:Static props:Resources.Word_Search}" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <Button Style="{StaticResource ToolbarButton}" Padding="5,3"
                        Click="FindButton_Click"
                        ToolTip="Ctrl+F">
                  <Path Data="M10,0 A5,5 0 1 0 10,10 A5,5 0 1 0 10,0 M14,10 L18,14"
                        Stroke="#5F6672" StrokeThickness="1.5" Fill="Transparent"
                        Width="16" Height="14" Stretch="Uniform"/>
                </Button>
                <ComboBox x:Name="SearchTextCombobox" Width="160" IsEditable="True" Margin="4,0"
                          PreviewKeyDown="SearchTextCombobox_PreviewKeyDown"/>
                <CheckBox x:Name="ExactMatchCheckBox" Content="{x:Static props:Resources.Word_ExactMatch}"
                          Margin="4,0" VerticalAlignment="Center" IsChecked="False"/>
                <CheckBox x:Name="CaseSensitiveCheckBox" Content="{x:Static props:Resources.Word_CaseSensitive}"
                          Margin="4,0" VerticalAlignment="Center" IsChecked="False"/>
                <CheckBox x:Name="RegexCheckBox" Content="{x:Static props:Resources.Word_Regex}"
                          Margin="4,0" VerticalAlignment="Center" IsChecked="False"/>
                <Button x:Name="PrevMatchCellButton" Style="{StaticResource ToolbarButton}"
                        Content="◀" FontSize="11" Padding="5,2" Margin="2,0"
                        Click="PrevMatchCellButton_Click"
                        ToolTip="{x:Static props:Resources.Shortcut_F8}"/>
                <Button x:Name="NextMatchCellButton" Style="{StaticResource ToolbarButton}"
                        Content="▶" FontSize="11" Padding="5,2"
                        Click="NextMatchCellButton_Click"
                        ToolTip="{x:Static props:Resources.Shortcut_F9}"/>
              </StackPanel>
            </DockPanel>
          </Border>

          <!--── Group: Options ──-->
          <Border Style="{StaticResource ToolbarGroup}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Bottom" Text="Options" HorizontalAlignment="Center"
                         FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,2"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                <CheckBox x:Name="IgnoreFileSettingCheckbox"
                          Content="{x:Static props:Resources.Label_IgnoreFileSetting}"
                          Margin="4,2" VerticalAlignment="Center"/>
              </StackPanel>
            </DockPanel>
          </Border>

        </StackPanel>
      </Border>

    <!--Search Overlay Panel (Ctrl+F quick search)-->
    <Border x:Name="SearchOverlayPanel"
            Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
            VerticalAlignment="Top" HorizontalAlignment="Right"
            Margin="0,4,20,0"
            Visibility="Collapsed"
            Panel.ZIndex="100"
            Background="{StaticResource PanelBgBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="4"
            Padding="8,5">
      <Border.Effect>
        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.18" Direction="270"/>
      </Border.Effect>
      <StackPanel Orientation="Horizontal">
        <ComboBox x:Name="SearchOverlayComboBox" Width="220" IsEditable="True" Margin="0,0,4,0"
                  VerticalContentAlignment="Center"
                  PreviewKeyDown="SearchOverlayComboBox_PreviewKeyDown"/>
        <CheckBox Content="{x:Static props:Resources.Word_ExactMatch}"
                  Margin="4,0" VerticalAlignment="Center"
                  IsChecked="{Binding IsChecked, ElementName=ExactMatchCheckBox, Mode=TwoWay}"/>
        <CheckBox Content="{x:Static props:Resources.Word_CaseSensitive}"
                  Margin="4,0" VerticalAlignment="Center"
                  IsChecked="{Binding IsChecked, ElementName=CaseSensitiveCheckBox, Mode=TwoWay}"/>
        <CheckBox Content="{x:Static props:Resources.Word_Regex}"
                  Margin="4,0" VerticalAlignment="Center"
                  IsChecked="{Binding IsChecked, ElementName=RegexCheckBox, Mode=TwoWay}"/>
        <Button Style="{StaticResource ToolbarButton}" Content="◀" FontSize="11" Padding="5,2" Margin="2,0"
                Click="SearchOverlayPrev_Click"
                ToolTip="{x:Static props:Resources.Shortcut_F8}"/>
        <Button Style="{StaticResource ToolbarButton}" Content="▶" FontSize="11" Padding="5,2" Margin="2,0"
                Click="SearchOverlayNext_Click"
                ToolTip="{x:Static props:Resources.Shortcut_F9}"/>
        <Button Style="{StaticResource ToolbarButton}" Content="✕" FontSize="10" Padding="4,2" Margin="2,0"
                Click="SearchOverlayClose_Click"
                ToolTip="Esc"/>
      </StackPanel>
    </Border>

    <!--Src Location Grid-->
    <Border BorderBrush="LightGray" BorderThickness="1" Grid.Column="0" Grid.Row="2" Margin="5,1,5,1">
      <Grid x:Name="SrcLocationGrid" ShowGridLines="False"
            MouseDown="LocationGrid_MouseDown" MouseMove="LocationGrid_MouseMove" MouseWheel="LocationGrid_MouseWheel"
            Background="#00000000">
        <Rectangle x:Name="SrcViewRectangle" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Fill="LightBlue" Opacity="0.5"
                   Width="{Binding ActualWidth, ElementName=SrcLocationGrid}"
                   Height="{Binding ActualHeight, ElementName=SrcLocationGrid}"
                   Panel.ZIndex="1"/>
      </Grid>
    </Border>

    <Border Grid.Column="0" Grid.Row="2" Margin="5,1,5,1"
            SizeChanged="LocationGrid_SizeChanged"/>

    <!--Dst Location Grid-->
    <Border BorderBrush="LightGray" BorderThickness="1" Grid.Column="6" Grid.Row="2" Margin="5,1,5,1">
      <Grid x:Name="DstLocationGrid" ShowGridLines="False"
            MouseDown="LocationGrid_MouseDown" MouseMove="LocationGrid_MouseMove" MouseWheel="LocationGrid_MouseWheel"
            Background="#00000000">
        <Rectangle x:Name="DstViewRectangle" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Fill="LightBlue" Opacity="0.5"
                   Width="{Binding ActualWidth, ElementName=DstLocationGrid}"
                   Height="{Binding ActualHeight, ElementName=DstLocationGrid}"
                   Panel.ZIndex="1"/>
      </Grid>
    </Border>

    <!--Src Grid-->
    <fg:FastGridControl x:Name="SrcDataGrid" Grid.Column="1" Grid.Row="2" Margin="1, 45, 1, 1"
                        IsTransposed="{Binding IsChecked, ElementName=chbIsTransposed1, Mode=TwoWay}"
                        UseClearType="{Binding IsChecked, ElementName=chbClearType1}"
                        IsReadOnly="True"
                        SizeChanged="DataGrid_SizeChanged"
                        SelectedCellsChanged="DataGrid_SelectedCellsChanged"
                        AllowDrop="True"
                        Tag="0"
                        RowHeightReserve="0"
                        >
      <i:Interaction.Behaviors>
        <behavior:DragAcceptBehavior 
                        Description="{Binding DataContext. Description,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
      </i:Interaction.Behaviors>

      <fg:FastGridControl.ContextMenu>
        <ContextMenu>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_SetRowHeader}" Click="SetRowHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_ResetRowHeader}" Click="ResetRowHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_SetColumnHeader}" Click="SetColumnHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_ResetColumnHeader}" Click="ResetColumnHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_DiffAsHeader}" Click="DiffByHeaderSrc_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_BuildCellBaseLog}" Click="BuildCellBaseLog_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_CopyAsTsv}" Click="CopyAsTsv_Click" InputGestureText="Ctrl + c"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_CopyAsCsv}" Click="CopyAsCsv_Click" InputGestureText="Ctrl + C"/>
          <Separator/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptSrc}" Click="AcceptSrc_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptDst}" Click="AcceptDst_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptSrcRow}" Click="AcceptSrcRow_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptDstRow}" Click="AcceptDstRow_Click"/>
        </ContextMenu>
      </fg:FastGridControl.ContextMenu>

    </fg:FastGridControl>

    <RichTextBox x:Name="SrcValueTextBox" Grid.Column="1" Grid.Row="2" Height="30" Margin="1" VerticalAlignment="Top"
                 GotFocus="ValueTextBox_GotFocus"
                 LostFocus="ValueTextBox_LostFocus"
                 Focusable="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.ScrollChanged ="ValuteTextBox_ScrollChanged"
                 />

    <GridSplitter Grid.Column="2" Grid.Row="2" Width="5" HorizontalAlignment="Center"/>

    <!-- BASE Grid (merge mode only, initially hidden) -->
    <fg:FastGridControl x:Name="BaseDataGrid" Grid.Column="3" Grid.Row="2" Margin="1, 45, 1, 1"
                        IsTransposed="{Binding IsChecked, ElementName=chbIsTransposed1, Mode=TwoWay}"
                        UseClearType="{Binding IsChecked, ElementName=chbClearType1}"
                        IsReadOnly="True"
                        SizeChanged="DataGrid_SizeChanged"
                        RowHeightReserve="0"
                        Visibility="Collapsed"
                        />

    <RichTextBox x:Name="BaseValueTextBox" Grid.Column="3" Grid.Row="2" Height="30" Margin="1" VerticalAlignment="Top"
                 Visibility="Collapsed"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 />

    <GridSplitter x:Name="BaseSplitter" Grid.Column="4" Grid.Row="2" Width="5" HorizontalAlignment="Center"
                  Visibility="Collapsed"/>

    <!--Dst Grid-->
    <fg:FastGridControl x:Name="DstDataGrid" Grid.Column="5" Grid.Row="2" Margin="1, 45, 1, 1"
                        IsTransposed="{Binding IsChecked, ElementName=chbIsTransposed1, Mode=TwoWay}"
                        UseClearType="{Binding IsChecked, ElementName=chbClearType1}"
                        IsReadOnly="True"
                        SizeChanged="DataGrid_SizeChanged"
                        SelectedCellsChanged="DataGrid_SelectedCellsChanged"
                        AllowDrop="True"
                        Tag="1"
                        RowHeightReserve="0"
                        >
      <i:Interaction.Behaviors>
        <behavior:DragAcceptBehavior 
                        Description="{Binding DataContext. Description,RelativeSource={RelativeSource AncestorType=UserControl}}"/>
      </i:Interaction.Behaviors>

      <fg:FastGridControl.ContextMenu>
        <ContextMenu>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_SetRowHeader}" Click="SetRowHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_ResetRowHeader}" Click="ResetRowHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_SetColumnHeader}" Click="SetColumnHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_ResetColumnHeader}" Click="ResetColumnHeader_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_DiffAsHeader}" Click="DiffByHeaderDst_Click" />
          <MenuItem Header="{x:Static props:Resources.ContextMenu_BuildCellBaseLog}" Click="BuildCellBaseLog_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_CopyAsTsv}" Click="CopyAsTsv_Click" InputGestureText="Ctrl + c"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_CopyAsCsv}" Click="CopyAsCsv_Click" InputGestureText="Ctrl + C"/>
          <Separator/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptSrc}" Click="AcceptSrc_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptDst}" Click="AcceptDst_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptSrcRow}" Click="AcceptSrcRow_Click"/>
          <MenuItem Header="{x:Static props:Resources.ContextMenu_AcceptDstRow}" Click="AcceptDstRow_Click"/>
        </ContextMenu>
      </fg:FastGridControl.ContextMenu>

    </fg:FastGridControl>

    <RichTextBox x:Name="DstValueTextBox" Grid.Column="5" Grid.Row="2" Height="30" Margin="1" VerticalAlignment="Top"
                 GotFocus="ValueTextBox_GotFocus"
                 LostFocus="ValueTextBox_LostFocus"
                 Focusable="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.ScrollChanged ="ValuteTextBox_ScrollChanged"
                 />

  </Grid>
</UserControl>
